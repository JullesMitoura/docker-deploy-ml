# =============================================================================
# .env.example  Template de variáveis de ambiente
#
# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
# O arquivo .env NÃO deve ser commitado (está no .gitignore).
# =============================================================================

# === Banco de dados ===
DB_PATH=data/heat_exchanger.db

# === Modelos ===
MODEL_DIR=models
MODEL_VERSION=          # vazio = usa model_latest.pkl

# === Servidor ===
PORT=8000

# === Logs ===
# dev:  DEBUG  (máxima verbosidade)
# prod: WARNING (apenas erros e avisos)
LOG_LEVEL=INFO